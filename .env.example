GOLDPAYMENTS_API_KEY="gold_live_key_a1b2c3d4e5..."
# GOLDPAYMENTS_APP_ID: The App ID for your Firebase project.
GOLDPAYMENTS_APP_ID="gold-payments-app-v7"
# GOLDPAYMENTS_PROJECT_ID: The Project ID for your Firebase project.
GOLDPAYMENTS_PROJECT_ID="goldpayments-prod-2026"
